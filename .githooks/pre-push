#!/bin/bash
# Dispatcher: runs all executable scripts in pre-push.d/
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)/pre-push.d"
if [ -d "$HOOK_DIR" ]; then
  for hook in "$HOOK_DIR"/*.sh; do
    [ -x "$hook" ] || continue
    "$hook"
    status=$?
    if [ $status -ne 0 ]; then
      exit $status
    fi
  done
fi
exit 0
