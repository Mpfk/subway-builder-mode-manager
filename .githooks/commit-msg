#!/bin/bash
# Dispatcher: runs all executable scripts in commit-msg.d/
# Passes $1 (commit message file path) to each sub-hook.
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)/commit-msg.d"
if [ -d "$HOOK_DIR" ]; then
  for hook in "$HOOK_DIR"/*.sh; do
    [ -x "$hook" ] || continue
    "$hook" "$1"
    status=$?
    if [ $status -ne 0 ]; then
      exit $status
    fi
  done
fi
exit 0
